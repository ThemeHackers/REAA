          "length"
        ]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "query_artifacts",
      "description": "Simple natural-language-like query over exported artifacts (function names, decompiled snippets).",
      "parameters": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "regex": {
            "type": "boolean",
            "description": "Enable regex search (default false)"
          }
        },
        "required": [
          "job_id",
          "query"
        ]
      }
    }
  }
